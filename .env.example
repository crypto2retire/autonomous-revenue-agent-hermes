# Venice AI (A0T Staking)
VENICE_API_KEY=your_venice_api_key_here
VENICE_BASE_URL=https://api.venice.ai/api/v1

# Blockchain RPC (Base Mainnet)
BASE_RPC_URL=https://mainnet.base.org
BASE_WALLET_PRIVATE_KEY=your_wallet_private_key_here
BASE_WALLET_ADDRESS=your_wallet_address_here

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/autonomous_agent
REDIS_URL=redis://localhost:6379/0

# WhatShouldICharge API
WSIC_API_KEY=your_wsic_api_key
WSIC_BASE_URL=https://api.whatshouldicharge.app

# Fly.io / Hosting
FLY_APP_NAME=autonomous-revenue-agent
FLY_REGION=ord

# Agent Configuration
AGENT_NAME=RevenueSeeker
AGENT_MODE=live
MAX_TRADE_SIZE_USD=100.00
DAILY_BUDGET_USD=50.00
RISK_PER_TRADE_PCT=2.0

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=8000

# Survival Thresholds
MIN_BALANCE_USD=10.00
HOSTING_COST_USD_PER_DAY=2.50
EMERGENCY_SHUTDOWN_BALANCE=5.00