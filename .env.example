# Crypto Trading Agent Environment Variables

# LLM Provider
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat

# Venice AI (fallback)
VENICE_API_KEY=your_venice_key_here

# Base Chain
BASE_WALLET_PRIVATE_KEY=your_base_private_key_here
BASE_WALLET_ADDRESS=your_base_address_here

# Solana Chain
SOLANA_WALLET_PRIVATE_KEY=your_solana_private_key_here
SOLANA_WALLET_ADDRESS=your_solana_address_here

# Database
DATABASE_URL=sqlite:///./agent.db

# APIs
BASESCAN_API_KEY=your_basescan_key_here
COINGECKO_API_KEY=your_coingecko_key_here
DUNE_API_KEY=your_dune_key_here
BIRDEYE_API_KEY=your_birdeye_key_here

# Trading Mode: paper or live
AGENT_MODE=paper

# Sell Agent Settings
SELL_AGENT_ENABLED=true
SELL_CHECK_INTERVAL_SECONDS=30
TRAILING_STOP_ENABLED=true
TRAILING_STOP_DISTANCE_PCT=0.10
PROFIT_TARGET_1_PCT=0.25
PROFIT_TARGET_1_SELL_PCT=0.60
PROFIT_TARGET_2_PCT=0.50
PROFIT_TARGET_2_SELL_PCT=0.80
MAX_HOLD_HOURS=168
UNDERPREFORM_SELL_THRESHOLD_PCT=-0.20
CAPITAL_RECYCLE_ENABLED=true
MIN_FREE_CAPITAL_PCT=0.20
EMERGENCY_STOP_LOSS_PCT=0.30
