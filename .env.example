# Venice AI
VENICE_API_KEY=your_venice_api_key

# Wallet (Base chain)
BASE_WALLET_PRIVATE_KEY=your_private_key_with_0x_prefix
BASE_WALLET_ADDRESS=your_wallet_address

# Database (Fly.io Postgres or local)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Optional: BaseScan API for holder data
BASESCAN_API_KEY=your_basescan_api_key

# Trading mode: paper or live
AGENT_MODE=paper

# Optional: WhatShouldICharge API
WSIC_API_KEY=your_wsic_key
